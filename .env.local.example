# ==========================================================================
#  ThreeWay Watchlist — environment variables
#  Copy this file to `.env.local` and fill in the values.
#  In Vercel, add these under Project Settings -> Environment Variables.
# ==========================================================================

# --- Server-only (NEVER exposed to the browser) ---------------------------
# TMDB "API Read Access Token" (v4 auth) — the long token, from
# themoviedb.org -> Settings -> API. Used only by the /api/tmdb route.
TMDB_TOKEN=

# --- Public (safe to expose; sent to the browser) -------------------------
# Supabase project URL and the PUBLISHABLE / anon key. Access is controlled
# by Row Level Security, so exposing the anon key is safe.
NEXT_PUBLIC_SUPABASE_URL=https://vfqlewzzpcortkfupckb.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
